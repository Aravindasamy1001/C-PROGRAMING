 for(int i = n - 1; i >= 1; i--) {

        // left spaces
        for(int j = 1; j <= n - i; j++) {
            printf(" ");
        }

        printf("*");

        if(i > 1) {
            for(int j = 1; j <= 2*i - 3; j++) {
                printf(" ");
            }
            printf("*");
        }

        printf("\n");
    }



    return 0;
}
